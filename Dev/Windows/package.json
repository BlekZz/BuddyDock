{
  "name": "buddydock",
  "version": "1.0.3",
  "description": "BuddyDock - Desktop virtual pet companion (Windows port)",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable",
    "dist:nsis": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.jessica.buddydock",
    "productName": "BuddyDock",
    "copyright": "Copyright © 2026 BuddyDock",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!electron/icon.iconset",
      "!electron/icon.icns"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "portable": {
      "artifactName": "BuddyDock-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "artifactName": "BuddyDock-${version}-setup.exe",
      "shortcutName": "BuddyDock",
      "runAfterFinish": true
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "koffi": "^2.15.6"
  }
}
